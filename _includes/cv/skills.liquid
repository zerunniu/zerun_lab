{% comment %}
  Local override of al_folio_cv skills template.
  Extends the gem's renderer to support RenderCV OneLineEntry (label/details)
  in addition to JSONResume (name/level/icon/keywords).
{% endcomment %}

<div class="card-text font-weight-light">
  {% for entry in entries %}
    <div class="skill-item">
      {% if entry.label %}
        <strong>{{ entry.label }}:</strong> {{ entry.details }}
      {% else %}
        {% if entry.icon %}
          <i class="{{ entry.icon }}"></i>
        {% endif %}
        <strong>
          {{- entry.name -}}
          {%- if entry.level %} ({{ entry.level }}){% endif %}:</strong
        >
        {% if entry.keywords %}
          {% if entry.keywords.first %}
            {% for keyword in entry.keywords %}
              {% if forloop.last %}
                {{ keyword }}
              {% else %}
                {{ keyword }},
              {% endif %}
            {% endfor %}
          {% else %}
            {{ entry.keywords }}
          {% endif %}
        {% endif %}
      {% endif %}
    </div>
  {% endfor %}
</div>

<style>
  .skill-item {
    padding: 0.5rem 0;
  }
</style>
